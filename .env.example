# Application Settings
APP_NAME="KaiTian"
APP_VERSION="0.1.0"
DEBUG=false
ENVIRONMENT=development

# Server Configuration
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# Reddit API Configuration
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT="KaiTian/0.1.0 by your_reddit_username"

# Database Configuration (SQLite for MVP)
DATABASE_URL=sqlite:///./kaitian.db
DATABASE_ECHO=false

# AI Service Configuration
AI_API_KEY=your_ai_api_key
AI_API_URL=your_ai_api_url

# External Service Integration
POSTIZ_API_KEY=your_postiz_api_key
LINU_API_KEY=your_linu_api_key
N8N_WEBHOOK_URL=your_n8n_webhook_url

# Crawl4AI Configuration
CRAWL4AI_ENABLED=true
CRAWL4AI_TIMEOUT=30
CRAWL4AI_BROWSER_TYPE=chromium

# MediaCrawler Configuration
MEDIA_CRAWLER_ENABLED=true
MEDIA_CRAWLER_TIMEOUT=30
MEDIA_CRAWLER_MAX_RETRIES=3

# Search Configuration
SEARCH_KEYWORDS=python,programming,automation
SUBREDDIT_LIST=python,learnprogramming,programming
SEARCH_INTERVAL_MINUTES=30
MAX_POSTS_PER_SEARCH=10

# Processing Configuration
RELEVANCE_THRESHOLD=0.7
MAX_CONCURRENT_REQUESTS=5
REQUEST_TIMEOUT_SECONDS=30
